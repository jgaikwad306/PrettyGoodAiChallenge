# --- Vapi (managed voice pipeline: telephony + STT + LLM + TTS) ---
# 1. Sign up at https://vapi.ai and grab an API key from dashboard -> Account.
# 2. Provision a phone number in dashboard -> Phone Numbers and copy its id.
# 3. Add your Anthropic, ElevenLabs, and (optionally) Deepgram credentials in
#    dashboard -> Provider Credentials so Vapi can use them per call.
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=

# --- Anthropic (used by the post-call analyzer; Vapi also uses your key) ---
ANTHROPIC_API_KEY=

# --- ElevenLabs voice id (the API key itself lives in the Vapi dashboard) ---
ELEVENLABS_VOICE_ID=

# --- Target (PGAI's test number for the real runs; swap to a friend's number for self-tests) ---
TARGET_NUMBER=+18054398008
